{
  "name": "custosoft-workers-api",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev":     "wrangler dev --local",
    "deploy":  "wrangler deploy",
    "types":   "wrangler types",
    "db:init": "wrangler d1 execute custosoft-db --file=schema.sql",
    "db:seed": "wrangler d1 execute custosoft-db --file=scripts/seed.sql",
    "db:migrate": "node scripts/migrate.js",
    "lint":    "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.5.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0"
  }
}
